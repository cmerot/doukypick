{
	"name": "doukypick",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"dev:tina": "tinacms dev -c \"vite dev\"",
		"build:tina": "tinacms build && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"storybook": "storybook dev -p 6006 --ci --disable-telemetry",
		"build-storybook": "storybook build -o static/storybook --disable-telemetry"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.1.1",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.7.0",
		"@playwright/test": "^1.58.2",
		"@storybook/addon-a11y": "^10.3.3",
		"@storybook/addon-docs": "^10.3.3",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.3.3",
		"@storybook/sveltekit": "^10.3.3",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@tinacms/cli": "^2.2.1",
		"@types/node": "^25.5.0",
		"@vitest/browser": "^4.1.2",
		"bits-ui": "^2.16.5",
		"clsx": "^2.1.1",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.3.3",
		"eslint-plugin-svelte": "^3.16.0",
		"formsnap": "^2.0.1",
		"globals": "^17.4.0",
		"lucide-svelte": "^1.0.1",
		"mdsvex": "^0.12.7",
		"mode-watcher": "^1.1.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"storybook": "^10.3.3",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tinacms": "^3.7.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vite": "^8.0.3",
		"vitest": "^4.1.2",
		"vitest-browser-svelte": "^2.1.0",
		"zod": "^4.3.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		],
		"ignoredBuiltDependencies": [
			"better-sqlite3",
			"core-js",
			"protobufjs"
		]
	},
	"dependencies": {
		"@vercel/blob": "^2.3.2"
	}
}
